# Copy to .env and fill in your own keys (`.env` is git-ignored).
#   cp .env.example .env  &&  $EDITOR .env
# Real environment variables override .env. The whole offline/structural path
# (model, compare, report, tiddlers, folder, latex, …) needs NO keys; only
# `mathpix`, `snip`, `bibfetch`, and `vision` call out.

# MathPix — https://mathpix.com/ (Console -> API Keys); free tier available.
MATHPIX_APP_ID=your_app_id_here
MATHPIX_APP_KEY=your_app_key_here

# Perplexity — https://www.perplexity.ai/ (Settings -> API).
PERPLEXITY_API_KEY=your_perplexity_key_here

# OpenAI — https://platform.openai.com/api-keys. GPT-4o vision for
# `pdfdrill vision`: reads CDN crops MathPix left as images (incl. table cells)
# → math / TikZ / gnuplot / table.
OPENAI_API_KEY=your_openai_key_here

# DeepL — https://www.deepl.com/your-account/keys. `pdfdrill translate` renders
# prose tiddlers into another language. A free key ends in `:fx`.
DEEPL_API_KEY=your_deepl_key_here
